{
  "openapi": "3.1.0",
  "info": {
    "title": "Clarify Complete OpenAPI Example",
    "summary": "A comprehensive OpenAPI fixture for renderer coverage.",
    "description": "This fixture intentionally exercises most OpenAPI structures Clarify needs to ingest and render: references, parameters, request bodies, responses, examples, callbacks, webhooks, security schemes, schema composition, nullable fields, discriminators and multiple content types.",
    "termsOfService": "https://clarify.local/terms",
    "contact": {
      "name": "Clarify Maintainers",
      "url": "https://github.com/taicode-labs/clarify",
      "email": "maintainers@clarify.local"
    },
    "license": {
      "name": "MIT",
      "identifier": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    },
    "version": "1.0.0"
  },
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "servers": [
    {
      "url": "https://api.clarify.local/{version}",
      "description": "Production",
      "variables": {
        "version": {
          "default": "v1",
          "enum": ["v1", "v2"],
          "description": "API version"
        }
      }
    },
    {
      "url": "https://staging-api.clarify.local/v1",
      "description": "Staging"
    }
  ],
  "externalDocs": {
    "description": "Clarify documentation",
    "url": "https://clarify.local/docs"
  },
  "tags": [
    {
      "name": "Pages",
      "description": "Document page management",
      "externalDocs": {
        "description": "Page guide",
        "url": "https://clarify.local/docs/pages"
      }
    },
    {
      "name": "Assets",
      "description": "Asset upload and metadata"
    },
    {
      "name": "Search",
      "description": "Search indexes and queries"
    },
    {
      "name": "System",
      "description": "Operational endpoints"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/pages": {
      "summary": "Pages collection",
      "description": "Create and list documentation pages.",
      "parameters": [
        {
          "$ref": "#/components/parameters/TraceId"
        }
      ],
      "get": {
        "tags": ["Pages"],
        "operationId": "listPages",
        "summary": "List pages",
        "description": "Returns a paginated list of pages with optional filters.",
        "parameters": [
          {
            "$ref": "#/components/parameters/PageCursor"
          },
          {
            "$ref": "#/components/parameters/PageLimit"
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter by publish status.",
            "schema": {
              "$ref": "#/components/schemas/PageStatus"
            },
            "examples": {
              "published": {
                "summary": "Only published pages",
                "value": "published"
              }
            }
          },
          {
            "name": "include",
            "in": "query",
            "description": "Related resources to include.",
            "style": "form",
            "explode": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["authors", "assets", "children"]
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A page collection.",
            "headers": {
              "X-Request-Id": {
                "$ref": "#/components/headers/RequestId"
              },
              "X-RateLimit-Remaining": {
                "$ref": "#/components/headers/RateLimitRemaining"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PageList"
                },
                "examples": {
                  "default": {
                    "$ref": "#/components/examples/PageListExample"
                  }
                }
              }
            },
            "links": {
              "GetPageById": {
                "$ref": "#/components/links/GetPageById"
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "default": {
            "$ref": "#/components/responses/UnexpectedError"
          }
        },
        "security": [
          {
            "BearerAuth": []
          },
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "tags": ["Pages"],
        "operationId": "createPage",
        "summary": "Create a page",
        "description": "Creates a new MDX-backed page.",
        "requestBody": {
          "required": true,
          "description": "Page payload.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PageCreate"
              },
              "examples": {
                "guide": {
                  "$ref": "#/components/examples/PageCreateExample"
                }
              }
            },
            "application/x-yaml": {
              "schema": {
                "type": "string",
                "description": "YAML representation of the page payload."
              },
              "example": "title: Getting Started\nslug: getting-started\ncontent: '# Hello'\n"
            }
          }
        },
        "responses": {
          "201": {
            "description": "Page created.",
            "headers": {
              "Location": {
                "description": "URL of the created page.",
                "schema": {
                  "type": "string",
                  "format": "uri"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Page"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "409": {
            "description": "Slug already exists.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/UnexpectedError"
          }
        },
        "callbacks": {
          "pagePublished": {
            "$ref": "#/components/callbacks/PagePublished"
          }
        }
      },
      "options": {
        "tags": ["System"],
        "operationId": "pagesOptions",
        "summary": "Describe page collection capabilities",
        "responses": {
          "204": {
            "description": "No content.",
            "headers": {
              "Allow": {
                "description": "Allowed methods.",
                "schema": {
                  "type": "string",
                  "example": "GET,POST,OPTIONS"
                }
              }
            }
          }
        }
      }
    },
    "/pages/{pageId}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/PageId"
        }
      ],
      "get": {
        "tags": ["Pages"],
        "operationId": "getPage",
        "summary": "Get a page",
        "description": "Gets a single page by ID.",
        "responses": {
          "200": {
            "description": "Page details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Page"
                },
                "examples": {
                  "default": {
                    "$ref": "#/components/examples/PageExample"
                  }
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "default": {
            "$ref": "#/components/responses/UnexpectedError"
          }
        }
      },
      "put": {
        "tags": ["Pages"],
        "operationId": "replacePage",
        "summary": "Replace a page",
        "requestBody": {
          "$ref": "#/components/requestBodies/PageUpsert"
        },
        "responses": {
          "200": {
            "description": "Updated page.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Page"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "patch": {
        "tags": ["Pages"],
        "operationId": "patchPage",
        "summary": "Patch a page",
        "requestBody": {
          "required": true,
          "content": {
            "application/merge-patch+json": {
              "schema": {
                "$ref": "#/components/schemas/PagePatch"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Patched page.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Page"
                }
              }
            }
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      },
      "delete": {
        "tags": ["Pages"],
        "operationId": "deletePage",
        "summary": "Delete a page",
        "responses": {
          "204": {
            "description": "Deleted."
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "head": {
        "tags": ["Pages"],
        "operationId": "headPage",
        "summary": "Check if a page exists",
        "responses": {
          "200": {
            "description": "Page exists.",
            "headers": {
              "ETag": {
                "description": "Entity tag.",
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/assets": {
      "post": {
        "tags": ["Assets"],
        "operationId": "uploadAsset",
        "summary": "Upload an asset",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file"],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "metadata": {
                    "$ref": "#/components/schemas/AssetMetadata"
                  }
                }
              },
              "encoding": {
                "metadata": {
                  "contentType": "application/json"
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Upload accepted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Asset"
                }
              }
            }
          }
        }
      }
    },
    "/search": {
      "get": {
        "tags": ["Search"],
        "operationId": "searchPages",
        "summary": "Search pages",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "example": "openapi"
          },
          {
            "name": "filters",
            "in": "query",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchFilters"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SearchResult"
                  }
                }
              },
              "text/csv": {
                "schema": {
                  "type": "string"
                },
                "example": "id,title,score\npg_123,Getting Started,0.97\n"
              }
            }
          }
        },
        "deprecated": false
      }
    },
    "/system/health": {
      "get": {
        "tags": ["System"],
        "operationId": "getHealth",
        "summary": "Get service health",
        "security": [],
        "responses": {
          "200": {
            "description": "Healthy service.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["status", "time"],
                  "properties": {
                    "status": {
                      "type": "string",
                      "const": "ok"
                    },
                    "time": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "trace": {
        "tags": ["System"],
        "operationId": "traceHealth",
        "summary": "Trace health request",
        "responses": {
          "200": {
            "description": "Trace response.",
            "content": {
              "message/http": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {
    "pageLifecycle": {
      "post": {
        "tags": ["Pages"],
        "operationId": "pageLifecycleWebhook",
        "summary": "Page lifecycle webhook",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/PagePublishedEvent"
                  },
                  {
                    "$ref": "#/components/schemas/PageDeletedEvent"
                  }
                ],
                "discriminator": {
                  "propertyName": "type",
                  "mapping": {
                    "page.published": "#/components/schemas/PagePublishedEvent",
                    "page.deleted": "#/components/schemas/PageDeletedEvent"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Webhook accepted."
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PageStatus": {
        "type": "string",
        "enum": ["draft", "published", "archived"]
      },
      "Identifier": {
        "type": "string",
        "pattern": "^[a-z]{2,}_[A-Za-z0-9]+$",
        "examples": ["pg_123"]
      },
      "Timestamp": {
        "type": "string",
        "format": "date-time",
        "examples": ["2026-06-17T12:00:00Z"]
      },
      "PageBase": {
        "type": "object",
        "required": ["id", "title", "slug", "status", "content", "createdAt", "updatedAt"],
        "properties": {
          "id": {
            "$ref": "#/components/schemas/Identifier"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "examples": ["Getting Started"]
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "status": {
            "$ref": "#/components/schemas/PageStatus"
          },
          "content": {
            "type": "string",
            "contentMediaType": "text/markdown"
          },
          "frontmatter": {
            "type": "object",
            "additionalProperties": true,
            "examples": [
              {
                "title": "Getting Started",
                "description": "Install Clarify in minutes"
              }
            ]
          },
          "parentId": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/Identifier"
              },
              {
                "type": "null"
              }
            ]
          },
          "createdAt": {
            "$ref": "#/components/schemas/Timestamp"
          },
          "updatedAt": {
            "$ref": "#/components/schemas/Timestamp"
          }
        }
      },
      "Page": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PageBase"
          },
          {
            "type": "object",
            "properties": {
              "links": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["href", "label"],
                  "properties": {
                    "href": {
                      "type": "string",
                      "format": "uri-reference"
                    },
                    "label": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        ]
      },
      "PageCreate": {
        "type": "object",
        "required": ["title", "slug", "content"],
        "properties": {
          "title": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/PageStatus"
          },
          "frontmatter": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      },
      "PagePatch": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/PageStatus"
          },
          "parentId": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/Identifier"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "minProperties": 1
      },
      "PageList": {
        "type": "object",
        "required": ["data", "pagination"],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Page"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          }
        }
      },
      "Pagination": {
        "type": "object",
        "required": ["limit", "hasMore"],
        "properties": {
          "cursor": {
            "type": "string"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 20
          },
          "hasMore": {
            "type": "boolean"
          }
        }
      },
      "AssetMetadata": {
        "type": "object",
        "properties": {
          "alt": {
            "type": "string"
          },
          "caption": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          }
        }
      },
      "Asset": {
        "type": "object",
        "required": ["id", "url", "contentType", "size"],
        "properties": {
          "id": {
            "$ref": "#/components/schemas/Identifier"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "contentType": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "minimum": 0
          },
          "metadata": {
            "$ref": "#/components/schemas/AssetMetadata"
          }
        }
      },
      "SearchFilters": {
        "type": "object",
        "properties": {
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "updatedAfter": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SearchResult": {
        "type": "object",
        "required": ["id", "title", "score"],
        "properties": {
          "id": {
            "$ref": "#/components/schemas/Identifier"
          },
          "title": {
            "type": "string"
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "highlight": {
            "type": "string"
          }
        }
      },
      "Problem": {
        "type": "object",
        "required": ["type", "title", "status"],
        "properties": {
          "type": {
            "type": "string",
            "format": "uri-reference"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "detail": {
            "type": "string"
          },
          "instance": {
            "type": "string",
            "format": "uri-reference"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["path", "message"],
              "properties": {
                "path": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "EventBase": {
        "type": "object",
        "required": ["id", "type", "createdAt"],
        "properties": {
          "id": {
            "$ref": "#/components/schemas/Identifier"
          },
          "type": {
            "type": "string"
          },
          "createdAt": {
            "$ref": "#/components/schemas/Timestamp"
          }
        }
      },
      "PagePublishedEvent": {
        "allOf": [
          {
            "$ref": "#/components/schemas/EventBase"
          },
          {
            "type": "object",
            "required": ["type", "data"],
            "properties": {
              "type": {
                "const": "page.published"
              },
              "data": {
                "$ref": "#/components/schemas/Page"
              }
            }
          }
        ]
      },
      "PageDeletedEvent": {
        "allOf": [
          {
            "$ref": "#/components/schemas/EventBase"
          },
          {
            "type": "object",
            "required": ["type", "data"],
            "properties": {
              "type": {
                "const": "page.deleted"
              },
              "data": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": {
                    "$ref": "#/components/schemas/Identifier"
                  }
                }
              }
            }
          }
        ]
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request.",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/Problem"
            },
            "examples": {
              "invalidCursor": {
                "summary": "Invalid cursor",
                "value": {
                  "type": "https://clarify.local/problems/invalid-cursor",
                  "title": "Invalid cursor",
                  "status": 400,
                  "detail": "The cursor is malformed."
                }
              }
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Missing or invalid credentials."
      },
      "NotFound": {
        "description": "Resource not found.",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/Problem"
            }
          }
        }
      },
      "ValidationError": {
        "description": "Validation failed.",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/Problem"
            }
          }
        }
      },
      "UnexpectedError": {
        "description": "Unexpected error.",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/Problem"
            }
          }
        }
      }
    },
    "parameters": {
      "TraceId": {
        "name": "X-Trace-Id",
        "in": "header",
        "description": "Optional trace ID propagated through the request.",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "PageId": {
        "name": "pageId",
        "in": "path",
        "required": true,
        "description": "Page identifier.",
        "schema": {
          "$ref": "#/components/schemas/Identifier"
        }
      },
      "PageCursor": {
        "name": "cursor",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "PageLimit": {
        "name": "limit",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 20
        }
      }
    },
    "examples": {
      "PageExample": {
        "summary": "A published page",
        "value": {
          "id": "pg_123",
          "title": "Getting Started",
          "slug": "getting-started",
          "status": "published",
          "content": "# Getting Started\n\nInstall Clarify.",
          "frontmatter": {
            "description": "Install Clarify in minutes"
          },
          "parentId": null,
          "createdAt": "2026-06-17T12:00:00Z",
          "updatedAt": "2026-06-17T12:00:00Z",
          "links": [
            {
              "href": "/getting-started",
              "label": "View page"
            }
          ]
        }
      },
      "PageListExample": {
        "summary": "A paginated page list",
        "value": {
          "data": [
            {
              "id": "pg_123",
              "title": "Getting Started",
              "slug": "getting-started",
              "status": "published",
              "content": "# Getting Started",
