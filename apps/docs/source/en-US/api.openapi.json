{
  "openapi": "3.1.0",
  "info": {
    "title": "Clarify Complete OpenAPI Example",
    "summary": "A complete OpenAPI example for renderer coverage.",
    "description": "A compact but broad OpenAPI example for Clarify. It keeps the operation count small while demonstrating full reference pages, tags, server variables, path/query/header parameters, JSON and YAML request bodies, multipart uploads, multiple response media types, examples, links, callbacks, webhooks, security schemes, schema composition, nullable fields, discriminators, and common JSON Schema validation keywords.",
    "termsOfService": "https://clarify.local/terms",
    "contact": {
      "name": "Clarify Maintainers",
      "url": "https://github.com/taicode-labs/clarify",
      "email": "maintainers@clarify.local"
    },
    "license": {
      "name": "MIT",
      "identifier": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    },
    "version": "1.0.0"
  },
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "servers": [
    {
      "url": "https://api.clarify.local/{version}",
      "description": "Production environment.",
      "variables": {
        "version": {
          "default": "v1",
          "enum": [
            "v1",
            "v2"
          ],
          "description": "API version."
        }
      }
    },
    {
      "url": "https://staging-api.clarify.local/v1",
      "description": "Staging environment."
    }
  ],
  "externalDocs": {
    "description": "Clarify documentation.",
    "url": "https://clarify.local/docs"
  },
  "tags": [
    {
      "name": "Pages",
      "description": "Documentation page management.",
      "externalDocs": {
        "description": "Page guide.",
        "url": "https://clarify.local/docs/pages"
      }
    },
    {
      "name": "Assets",
      "description": "Asset uploads and metadata."
    },
    {
      "name": "Search",
      "description": "Search indexing and queries."
    },
    {
      "name": "System",
      "description": "Operational status endpoints."
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/examples/basic-request": {
      "$ref": "./api.openapi/paths/examples-basic-request.json"
    },
    "/examples/path-parameters/{pageId}": {
      "$ref": "./api.openapi/paths/examples-path-parameters-by-pageid.json"
    },
    "/examples/query-parameters": {
      "$ref": "./api.openapi/paths/examples-query-parameters.json"
    },
    "/examples/complex-request-body": {
      "$ref": "./api.openapi/paths/examples-complex-request-body.json"
    },
    "/examples/basic-response": {
      "$ref": "./api.openapi/paths/examples-basic-response.json"
    },
    "/examples/variable-server-matrix": {
      "$ref": "./api.openapi/paths/examples-variable-server-matrix.json"
    },
    "/examples/long-enum": {
      "get": {
        "tags": [
          "System"
        ],
        "operationId": "demoLongEnum",
        "summary": "Long enum rendering example",
        "description": "This endpoint exposes a response schema with many enum values so the expandable enum list can be inspected in the API reference.",
        "responses": {
          "200": {
            "description": "Example payload with long enums.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EnumPreviewResponse"
                }
              }
            }
          }
        }
      }
    },
    "/examples/single-server": {
      "get": {
        "tags": [
          "Assets"
        ],
        "operationId": "demoSingleServer",
        "summary": "Multiple fixed asset servers",
        "description": "Provides multiple fixed server URLs without variables, so clicking the server opens the URL selector directly.",
        "security": [],
        "servers": [
          {
            "url": "https://assets.clarify.local/v1",
            "description": "Production asset server."
          },
          {
            "url": "https://staging-assets.clarify.local/v1",
            "description": "Staging asset server."
          }
        ],
        "responses": {
          "200": {
            "description": "Current API build metadata.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "version",
                    "commit"
                  ],
                  "properties": {
                    "version": {
                      "type": "string",
                      "example": "1.0.0"
                    },
                    "commit": {
                      "type": "string",
                      "example": "a1b2c3d"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {
    "pageLifecycle": {
      "post": {
        "tags": [
          "Pages"
        ],
        "operationId": "pageLifecycleWebhook",
        "summary": "Page lifecycle webhook",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/PagePublishedEvent"
                  },
                  {
                    "$ref": "#/components/schemas/PageDeletedEvent"
                  }
                ],
                "discriminator": {
                  "propertyName": "type",
                  "mapping": {
                    "page.published": "#/components/schemas/PagePublishedEvent",
                    "page.deleted": "#/components/schemas/PageDeletedEvent"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Webhook accepted."
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PageStatus": {
        "type": "string",
        "enum": [
          "draft",
          "published",
          "archived"
        ],
        "description": "Clarify renders string enums as constrained values and shows every option in schema tables."
      },
      "EnumPreviewResponse": {
        "type": "object",
        "required": [
          "mode",
          "status",
          "channel"
        ],
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "preview",
              "review",
              "publish",
              "archive",
              "delete",
              "restore",
              "duplicate",
              "rollback",
              "migrate",
              "snapshot",
              "compare",
              "schedule"
            ],
            "description": "Long enum values used to preview expandable enum rendering."
          },
          "status": {
            "type": "string",
            "enum": [
              "queued",
              "processing",
              "ready",
              "failed",
              "canceled",
              "retrying",
              "timed_out",
              "partial",
              "complete"
            ],
            "description": "Another long enum list to inspect the nested child rendering."
          },
          "channel": {
            "type": "string",
            "enum": [
              "email",
              "slack",
              "webhook",
              "teams",
              "sms",
              "push",
              "chat",
              "rss",
              "api",
              "desktop"
            ],
            "description": "Delivery channel enum for a second expandable example."
          }
        },
        "description": "Response schema with multiple long enums for inspecting the new expandable enum rendering."
      },
      "Identifier": {
        "type": "string",
        "pattern": "^[a-z]{2,}_[A-Za-z0-9]+$",
        "examples": [
          "pg_123"
        ],
        "description": "Reusable scalar schema that demonstrates $ref, pattern, and examples."
      },
      "Timestamp": {
        "type": "string",
        "format": "date-time",
        "examples": [
          "2026-06-17T12:00:00Z"
        ],
        "description": "Clarify displays string formats such as date-time and scalar examples."
      },
      "PageBase": {
        "type": "object",
        "required": [
          "id",
          "title",
          "slug",
          "status",
          "content",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "$ref": "#/components/schemas/Identifier",
            "description": "Reusable identifier reference."
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "examples": [
              "Getting Started"
            ],
            "description": "Required string with minLength and maxLength constraints."
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "description": "Route segment constrained by a pattern."
          },
          "status": {
            "$ref": "#/components/schemas/PageStatus",
            "description": "Referenced enum for draft, published, and archived states."
          },
          "content": {
            "type": "string",
            "contentMediaType": "text/markdown",
            "description": "Markdown or MDX source content marked with contentMediaType."
          },
          "frontmatter": {
            "type": "object",
            "additionalProperties": true,
            "examples": [
              {
                "title": "Getting Started",
                "description": "Install Clarify in minutes"
              }
            ],
            "description": "Flexible metadata object demonstrating additionalProperties."
          },
          "parentId": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/Identifier"
              },
              {
                "type": "null"
              }
            ],
            "description": "Nullable parent relation represented with oneOf and null."
          },
          "createdAt": {
            "$ref": "#/components/schemas/Timestamp",
            "description": "Creation time."
          },
          "updatedAt": {
            "$ref": "#/components/schemas/Timestamp",
            "description": "Update time."
          }
        },
        "description": "Base page model with required fields, nested metadata, nullable references, and Markdown content annotations."
      },
      "Page": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PageBase"
          },
          {
            "type": "object",
            "properties": {
              "links": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "href",
                    "label"
                  ],
                  "properties": {
                    "href": {
                      "type": "string",
                      "format": "uri-reference",
                      "description": "Related page link."
                    },
                    "label": {
                      "type": "string",
                      "description": "Readable link label."
                    }
                  }
                },
                "description": "Inline object array with required nested fields and URI-reference values."
              }
            }
          }
        ],
        "description": "Clarify resolves allOf composition so shared and extended fields can be shown together."
      },
      "PageCreate": {
        "type": "object",
        "required": [
          "title",
          "slug",
          "content"
        ],
        "properties": {
          "title": {
            "type": "string",
            "description": "Title for a new page."
          },
          "slug": {
            "type": "string",
            "description": "Slug for a new page."
          },
          "content": {
            "type": "string",
            "description": "Submitted MDX or Markdown source."
          },
          "status": {
            "$ref": "#/components/schemas/PageStatus",
            "description": "Optional reusable enum."
          },
          "frontmatter": {
            "type": "object",
            "additionalProperties": true,
            "description": "Flexible frontmatter object accepted by create requests."
          }
        },
        "additionalProperties": false,
        "description": "Request-only object schema with required fields and additionalProperties constraints."
      },
      "PageList": {
        "type": "object",
        "required": [
          "data",
          "pagination"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Page"
            },
            "description": "Array of referenced Page objects."
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          }
        },
        "description": "Clarify renders arrays of referenced objects and nested pagination models."
      },
      "Pagination": {
        "type": "object",
        "required": [
          "limit",
          "hasMore"
        ],
        "properties": {
          "cursor": {
            "type": "string",
            "description": "Opaque pagination cursor."
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 20,
            "description": "Integer with minimum, maximum, and default."
          },
          "hasMore": {
            "type": "boolean",
            "description": "Whether another page is available."
          }
        },
        "description": "Pagination model with integer ranges, defaults, and booleans."
      },
      "AssetMetadata": {
        "type": "object",
        "properties": {
          "alt": {
            "type": "string",
            "description": "Image alternative text."
          },
          "caption": {
            "type": "string",
            "description": "Optional asset caption."
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true,
            "description": "Unique string array for array constraint rendering."
          }
        },
        "description": "Metadata used by multipart upload examples."
      },
      "Asset": {
        "type": "object",
        "required": [
          "id",
          "url",
          "contentType",
          "size"
        ],
        "properties": {
          "id": {
            "$ref": "#/components/schemas/Identifier",
            "description": "Reusable asset identifier."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Absolute uploaded asset URI."
          },
          "contentType": {
            "type": "string",
            "description": "Returned MIME type."
          },
          "size": {
            "type": "integer",
            "minimum": 0,
            "description": "Non-negative byte size."
          },
          "metadata": {
            "$ref": "#/components/schemas/AssetMetadata",
            "description": "Nested metadata reused from multipart requests."
          }
        },
        "description": "Asset model covering URI strings, non-negative integers, and nested metadata."
      },
      "SearchFilters": {
        "type": "object",
        "properties": {
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array filters encoded in a JSON query parameter."
          },
          "updatedAfter": {
            "type": "string",
            "format": "date-time",
            "description": "date-time filter used inside query content."
          }
        },
        "description": "Object query parameter encoded as JSON content."
      },
      "SearchResult": {
        "type": "object",
        "required": [
          "id",
          "title",
          "score"
        ],
        "properties": {
          "id": {
            "$ref": "#/components/schemas/Identifier",
            "description": "Matched page identifier."
          },
          "title": {
            "type": "string",
            "description": "Matched page title."
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Score between 0 and 1 for numeric boundary rendering."
          },
          "highlight": {
            "type": "string",
            "description": "Optional highlighted snippet."
          }
        },
        "description": "Search result object used in array responses."
      },
      "ExportRequest": {
        "type": "object",
        "required": [
          "format",
          "scope",
          "selection",
          "rendering",
          "delivery"
        ],
        "properties": {
          "format": {
            "type": "string",
            "enum": [
              "html",
              "pdf",
              "markdown"
            ],
            "description": "Output format enum."
          },
          "scope": {
            "type": "string",
            "enum": [
              "site",
              "published",
              "selected"
            ],
            "description": "Export scope enum."
          },
          "includeDrafts": {
            "type": "boolean",
            "default": false,
            "description": "Boolean with default value."
          },
          "callbackUrl": {
            "type": "string",
            "format": "uri",
            "description": "Optional callback URL for operation callbacks."
          },
          "selection": {
            "type": "object",
            "required": [
              "mode",
              "items"
            ],
            "properties": {
              "mode": {
                "type": "string",
                "enum": [
                  "all",
                  "ids",
                  "query"
                ],
                "description": "Controls how the selected resources are resolved."
              },
              "items": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": [
                    "id",
                    "type"
                  ],
                  "properties": {
                    "id": {
                      "$ref": "#/components/schemas/Identifier",
                      "description": "Selected resource identifier."
                    },
                    "type": {
                      "type": "string",
                      "enum": [
                        "page",
                        "section",
                        "asset"
                      ],
                      "description": "Selected resource type."
                    },
                    "options": {
                      "type": "object",
                      "additionalProperties": {
                        "oneOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "number"
                          },
                          {
                            "type": "boolean"
                          }
                        ]
                      },
                      "description": "Free-form per-item options with primitive values."
                    }
                  }
                },
                "description": "Nested array of selected resources."
              },
              "query": {
                "$ref": "#/components/schemas/SearchFilters",
                "description": "Optional object query used when mode is query."
              }
            },
            "description": "Nested object showing required child properties, arrays, references, and additionalProperties."
          },
          "rendering": {
            "type": "object",
            "required": [
              "theme",
              "assets"
            ],
            "properties": {
              "theme": {
                "oneOf": [
                  {
                    "const": "system",
                    "description": "Use the default theme."
                  },
                  {
                    "type": "object",
                    "required": [
                      "name",
                      "tokens"
                    ],
                    "properties": {
                      "name": {
                        "type": "string",
                        "description": "Custom theme name."
                      },
                      "tokens": {
                        "type": "object",
                        "additionalProperties": {
                          "type": "string",
                          "pattern": "^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$"
                        },
                        "description": "Color token map constrained to hex colors."
                      }
                    }
                  }
                ],
                "description": "oneOf value that can be a const string or an inline object."
              },
              "assets": {
                "type": "object",
                "required": [
                  "embed",
                  "metadata"
                ],
                "properties": {
                  "embed": {
                    "type": "boolean",
                    "default": true,
                    "description": "Whether assets should be embedded."
                  },
                  "metadata": {
                    "$ref": "#/components/schemas/AssetMetadata",
                    "description": "Referenced nested metadata schema."
                  }
                }
              }
            },
            "description": "Rendering settings with oneOf, const, defaults, nested objects, and refs."
          },
          "delivery": {
            "type": "object",
            "required": [
              "channels"
            ],
            "properties": {
              "channels": {
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "kind",
                        "email"
                      ],
                      "properties": {
                        "kind": {
                          "const": "email"
                        },
                        "email": {
                          "type": "string",
                          "format": "email"
                        }
                      }
                    },
                    {
                      "type": "object",
                      "required": [
                        "kind",
                        "url"
                      ],
                      "properties": {
                        "kind": {
                          "const": "webhook"
                        },
                        "url": {
                          "type": "string",
                          "format": "uri"
                        }
                      }
                    }
                  ]
                },
                "description": "Array of oneOf channel objects with const discriminators."
              },
              "expiresAt": {
                "oneOf": [
                  {
                    "type": "string",
                    "format": "date-time"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Nullable expiration timestamp."
              }
            },
            "description": "Delivery configuration with arrays, oneOf branches, formats, and nullability."
          }
        },
        "description": "Complex nested export request covering enums, defaults, references, arrays, oneOf, const, formats, patterns, and additionalProperties."
      },
      "ExportJob": {
        "type": "object",
        "required": [
          "id",
          "status",
          "downloadUrl"
        ],
        "properties": {
          "id": {
            "$ref": "#/components/schemas/Identifier",
            "description": "Reusable job identifier."
          },
          "status": {
            "type": "string",
            "enum": [
              "queued",
              "processing",
              "ready",
              "failed"
            ],
            "description": "Async job lifecycle enum."
          },
          "downloadUrl": {
            "oneOf": [
              {
                "type": "string",
                "format": "uri"
              },
              {
                "type": "null"
              }
            ],
            "description": "Nullable URI available when export completes."
          }
        },
        "description": "Async job model with nullable fields and status enums."
      },
      "Problem": {
        "type": "object",
        "required": [
          "type",
          "title",
          "status"
        ],
        "properties": {
          "type": {
            "type": "string",
            "format": "uri-reference",
            "description": "Problem type URI-reference."
          },
          "title": {
            "type": "string",
            "description": "Short readable error title."
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code."
          },
          "detail": {
            "type": "string",
            "description": "Optional detailed error message."
          },
          "instance": {
            "type": "string",
            "format": "uri-reference",
            "description": "Optional URI-reference for this error instance."
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "path",
                "message"
              ],
              "properties": {
                "path": {
                  "type": "string",
                  "description": "JSON Pointer or dotted invalid field path."
                },
                "message": {
                  "type": "string",
                  "description": "Validation message for the field path."
                }
              }
            },
            "description": "Nested validation errors with required child properties."
          }
        },
        "description": "RFC 7807-style problem details with nested validation errors."
      },
      "EventBase": {
        "type": "object",
        "required": [
          "id",
          "type",
          "createdAt"
        ],
        "properties": {
          "id": {
            "$ref": "#/components/schemas/Identifier",
            "description": "Reusable event identifier."
          },
          "type": {
            "type": "string",
            "description": "Event type used by the discriminator."
          },
          "createdAt": {
            "$ref": "#/components/schemas/Timestamp",
            "description": "Event emission time."
          }
        },
        "description": "Event envelope reused by callbacks and webhooks."
      },
      "PagePublishedEvent": {
        "allOf": [
          {
            "$ref": "#/components/schemas/EventBase"
          },
          {
            "type": "object",
            "required": [
              "type",
              "data"
            ],
            "properties": {
              "type": {
                "const": "page.published",
                "description": "Const event type used by discriminator mapping."
              },
              "data": {
                "$ref": "#/components/schemas/Page",
                "description": "Event payload rendered from a referenced schema."
              }
            }
          }
        ],
        "description": "Event variant combining allOf and const for discriminator support."
      },
      "PageDeletedEvent": {
        "allOf": [
          {
            "$ref": "#/components/schemas/EventBase"
          },
          {
            "type": "object",
            "required": [
              "type",
              "data"
            ],
            "properties": {
              "type": {
                "const": "page.deleted",
                "description": "Const event type used by discriminator mapping."
              },
              "data": {
                "type": "object",
                "required": [
                  "id"
                ],
                "properties": {
                  "id": {
                    "$ref": "#/components/schemas/Identifier"
                  }
                },
                "description": "Compact event payload rendered from an inline schema."
              }
            }
          }
        ],
        "description": "Second discriminator branch using a compact data payload."
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request.",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/Problem"
            },
            "examples": {
              "invalidCursor": {
                "summary": "Invalid cursor",
                "value": {
                  "type": "https://clarify.local/problems/invalid-cursor",
                  "title": "Invalid cursor",
                  "status": 400,
                  "detail": "The cursor is malformed."
                }
              }
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Missing or invalid credentials."
      },
      "NotFound": {
