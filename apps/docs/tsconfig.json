{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@clarify/renderer": ["../../packages/renderer/source/index.tsx"],
      "@clarify/renderer/*": ["../../packages/renderer/source/*"]
    }
  },
  "include": ["source"],
  "exclude": ["node_modules", "output"]
}
