{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@clarify/renderer": ["../../packages/renderer/source/index.tsx"],
      "@clarify/renderer/*": ["../../packages/renderer/source/*"],
      "@clarify/vite-plugin": ["../../packages/vite-plugin/source/index.ts"],
      "@clarify/vite-plugin/*": ["../../packages/vite-plugin/source/*"]
    }
  },
  "include": ["source", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
