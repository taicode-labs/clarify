{
  "name": "@clarify-labs/cli",
  "version": "0.10.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/taicode-labs/clarify",
    "directory": "packages/cli"
  },
  "main": "output/index.cjs",
  "module": "output/index.js",
  "types": "output/index.d.ts",
  "bin": {
    "clarify": "bin/clarify.js"
  },
  "exports": {
    ".": {
      "types": "./output/index.d.ts",
      "import": "./output/index.js",
      "require": "./output/index.cjs",
      "default": "./output/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "LICENSE",
    "bin",
    "output"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "lint": "eslint source/",
    "lint:fix": "eslint source/ --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@clarify-labs/renderer": "workspace:*",
    "@clarify-labs/templates": "workspace:*",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "cac": "^7.0.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "mdast-util-to-string": "^4.0.0",
    "mermaid": "^11.4.0",
    "openapi-types": "^12.1.3",
    "pagefind": "^1.5.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.0.0",
    "react-router-dom": "^7.0.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "shiki": "4.3.1",
    "unist-util-visit": "^5.1.0",
    "vite": "^8.1.4",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "typescript": "^6.0.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  }
}
