{
  "name": "@clarify/renderer",
  "version": "0.1.0",
  "type": "module",
  "main": "output/index.cjs",
  "module": "output/index.js",
  "types": "output/index.d.ts",
  "exports": {
    ".": {
      "types": "./output/index.d.ts",
      "import": "./output/index.js",
      "require": "./output/index.cjs",
      "default": "./output/index.js"
    },
    "./server": {
      "types": "./output/server.d.ts",
      "import": "./output/server.js",
      "require": "./output/server.cjs",
      "default": "./output/server.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "output"
  ],
  "scripts": {
    "dev": "tsup source/index.tsx source/server.tsx --format esm,cjs --dts --watch --outDir output --external tailwindcss",
    "build": "tsup source/index.tsx source/server.tsx --format esm,cjs --dts --outDir output --external tailwindcss",
    "lint": "eslint source/",
    "lint:fix": "eslint source/ --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare": "pnpm build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
