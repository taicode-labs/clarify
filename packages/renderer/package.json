{
  "name": "@clarify/renderer",
  "version": "0.1.0",
  "type": "module",
  "main": "output/index.cjs",
  "module": "output/index.js",
  "types": "output/index.d.ts",
  "exports": {
    ".": {
      "types": "./output/index.d.ts",
      "import": "./output/index.js",
      "require": "./output/index.cjs",
      "default": "./output/index.js"
    },
    "./server": {
      "types": "./output/server.d.ts",
      "import": "./output/server.js",
      "require": "./output/server.cjs",
      "default": "./output/server.js"
    },
    "./style.css": "./output/renderer.css",
    "./package.json": "./package.json"
  },
  "files": [
    "output"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "lint": "eslint source/",
    "lint:fix": "eslint source/ --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/github-slugger": "^2.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "vite": "^8.0.15",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@tailwindcss/typography": "^0.5.20",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "github-slugger": "^2.0.0",
    "lucide-react": "^1.20.0",
    "openapi-types": "^12.1.3",
    "zustand": "^5.0.14"
  }
}
