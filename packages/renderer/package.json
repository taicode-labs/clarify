{
  "name": "@clarify-labs/renderer",
  "version": "0.11.6",
  "license": "AGPL-3.0-only",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/taicode-labs/clarify",
    "directory": "packages/renderer"
  },
  "main": "output/index.cjs",
  "module": "output/index.js",
  "types": "output/index.d.ts",
  "exports": {
    ".": {
      "types": "./output/index.d.ts",
      "import": "./output/index.js",
      "require": "./output/index.cjs",
      "default": "./output/index.js"
    },
    "./markdown": {
      "types": "./output/markdown.d.ts",
      "import": "./output/markdown.js",
      "require": "./output/markdown.cjs",
      "default": "./output/markdown.js"
    },
    "./preview": {
      "types": "./output/preview.d.ts",
      "import": "./output/preview.js",
      "require": "./output/preview.cjs",
      "default": "./output/preview.js"
    },
    "./client": {
      "types": "./output/client.d.ts",
      "import": "./output/client.js",
      "require": "./output/client.cjs",
      "default": "./output/client.js"
    },
    "./server": {
      "types": "./output/server.d.ts",
      "import": "./output/server.js",
      "require": "./output/server.cjs",
      "default": "./output/server.js"
    },
    "./style.css": "./output/renderer.css",
    "./package.json": "./package.json"
  },
  "files": [
    "LICENSE",
    "output"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "lint": "eslint source/",
    "lint:fix": "eslint source/ --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@scalar/snippetz": "^0.9.17",
    "@tailwindcss/typography": "^0.5.20",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "github-slugger": "^2.0.0",
    "lucide-react": "^1.20.0",
    "mermaid": "^11.4.0",
    "openapi-types": "^12.1.3",
    "react-markdown": "^10.1.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.0",
    "yaml": "^2.9.0",
    "zustand": "^5.0.14"
  }
}
