{
  "name": "@clarify/vite-plugin",
  "version": "0.1.0",
  "type": "module",
  "main": "output/index.cjs",
  "module": "output/index.js",
  "types": "output/index.d.ts",
  "exports": {
    ".": {
      "types": "./output/index.d.ts",
      "import": "./output/index.js",
      "require": "./output/index.cjs",
      "default": "./output/index.js"
    }
  },
  "files": [
    "output"
  ],
  "scripts": {
    "dev": "tsup source/index.ts --format esm,cjs --dts --watch --outDir output --external @clarify/renderer/server --external react/jsx-runtime",
    "build": "tsup source/index.ts --format esm,cjs --dts --outDir output --external @clarify/renderer/server --external react/jsx-runtime",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "vite": "^8.0.15"
  },
  "devDependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
