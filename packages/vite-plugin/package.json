{
  "name": "@clarify/vite-plugin",
  "version": "0.1.0",
  "type": "module",
  "main": "output/index.cjs",
  "module": "output/index.js",
  "types": "output/index.d.ts",
  "exports": {
    ".": {
      "types": "./output/index.d.ts",
      "import": "./output/index.js",
      "require": "./output/index.cjs",
      "default": "./output/index.js"
    }
  },
  "files": [
    "output"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "lint": "eslint source/",
    "lint:fix": "eslint source/ --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/vite": "^4.1.11",
    "@vitejs/plugin-react": "^6.0.2",
    "vite": "^8.0.15",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "typescript": "^5.8.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.9"
  }
}
