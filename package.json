{
  "name": "clarify",
  "version": "0.1.0",
  "private": true,
  "description": "An open-source documentation publishing tool built for MDX and OpenAPI.",
  "scripts": {
    "dev": "turbo run dev",
    "dev:docs": "turbo run dev --filter=@clarify/docs",
    "dev:www": "turbo run dev --filter=@clarify/www",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "pnpm --recursive --if-present lint",
    "test": "turbo run test"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "turbo": "^2.9.18"
  }
}
