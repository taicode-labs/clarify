{
  "name": "clarify",
  "version": "0.6.2",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "An open-source documentation publishing tool built for MDX and OpenAPI.",
  "scripts": {
    "dev": "turbo run dev",
    "dev:docs": "turbo run dev --filter=@clarify-labs/docs",
    "dev:www": "turbo run dev --filter=@clarify-labs/www",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint": "^9.6.1",
    "@yinxulai/eslint-plugin-peculiar": "^1.0.6",
    "eslint": "^10.5.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-mdx": "^3.8.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "turbo": "^2.9.18",
    "typescript-eslint": "^8.61.1"
  }
}
